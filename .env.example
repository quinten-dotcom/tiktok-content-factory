# Copy this to .env and fill in your keys

# Claude API (for script generation + QA)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# fal.ai (for Flux image generation)
FAL_KEY=xxxxx

# ElevenLabs (for voiceover — optional, can use Kokoro instead)
ELEVENLABS_API_KEY=xxxxx

# TikTok Content Posting API (for auto-uploading)
TIKTOK_CLIENT_KEY=xxxxx
TIKTOK_CLIENT_SECRET=xxxxx

# Voice engine: "elevenlabs" or "kokoro"
VOICE_ENGINE=elevenlabs

# Image engine: "flux_schnell" (cheap) or "flux_kontext" (character consistent)
IMAGE_ENGINE=flux_schnell

# Videos per day per app
VIDEOS_PER_DAY=7

# QA threshold (1-10, videos scoring below this get regenerated)
QA_THRESHOLD=7
